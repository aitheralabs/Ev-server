      "sanitize": "mongo"
    },
    "Limit": {
      "$ref": "common#/definitions/limit"
    },
    "Skip": {
      "$ref": "common#/definitions/skip"
    },
    "SortFields": {
      "$ref": "common#/definitions/sortFields"
    },
    "ProjectFields": {
      "$ref": "common#/definitions/projectFields"
    }
  },
  "required": ["Limit"]
}
